@baseUrl = http://localhost:9002
@userId = 1
@apiKey = change_me_api_key

### Crear usuario
POST {{baseUrl}}/api/usuarios
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "nombre": "Cesar",
  "apellido": "Lopez",
  "email": "cesar@example.com",
  "telefono": "+56999999999",
  "password": "Passw0rd!Segura",
  "token_fcm": null
}

### Listar usuarios
GET {{baseUrl}}/api/usuarios
x-api-key: {{apiKey}}

### Obtener usuario
GET {{baseUrl}}/api/usuarios/{{userId}}
x-api-key: {{apiKey}}

### Actualizar usuario
PATCH {{baseUrl}}/api/usuarios/{{userId}}
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "nombre": "Cesar Modificado",
  "telefono": "+56911111111"
}

### Actualizar token FCM
PATCH {{baseUrl}}/api/usuarios/{{userId}}/token-fcm
Content-Type: application/json
x-api-key: {{apiKey}}

{
  "token_fcm": "new_token_example_123"
}

### Eliminar usuario
DELETE {{baseUrl}}/api/usuarios/{{userId}}
x-api-key: {{apiKey}}
