    {
      "name": "01 - Auth",
      "description": "Registro, login y sesion del usuario.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201/200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "let json;",
                  "try { json = pm.response.json(); } catch (e) { json = null; }",
                  "if (json && json.data) {",
                  "  if (json.data.access_token) { pm.environment.set('jwt', json.data.access_token); }",
                  "  if (json.data.user && json.data.user.id) { pm.environment.set('userId', String(json.data.user.id)); }",
                  "  if (json.data.user && json.data.user.email) { pm.environment.set('email', json.data.user.email); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"{{nombre}}\",\n  \"apellido\": \"{{apellido}}\",\n  \"email\": \"{{email}}\",\n  \"telefono\": \"{{telefono}}\",\n  \"password\": \"{{password}}\",\n  \"token_fcm\": \"{{tokenFcm}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Crea usuario y devuelve access_token."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "let json;",
                  "try { json = pm.response.json(); } catch (e) { json = null; }",
                  "if (json && json.data) {",
                  "  if (json.data.access_token) { pm.environment.set('jwt', json.data.access_token); }",
                  "  if (json.data.user && json.data.user.id) { pm.environment.set('userId', String(json.data.user.id)); }",
                  "  if (json.data.user && json.data.user.email) { pm.environment.set('email', json.data.user.email); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesion y actualiza variable jwt."
          },
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Valida token y devuelve perfil actual."
          },
          "response": []
        }
      ]
